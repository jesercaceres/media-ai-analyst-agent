# =====================================================================
# Google Gemini (LLM)
# =====================================================================

# Google AI Studio API Key (obrigatório, gratuito)
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# =====================================================================
# Google Cloud / BigQuery
# =====================================================================

# Caminho absoluto para o arquivo de credenciais JSON da Service Account
# Obtenha em: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_APPLICATION_CREDENTIALS=C:\caminho\para\sua\service-account.json

# ID do projeto GCP (ex: meu-projeto-12345)
GCP_PROJECT_ID=seu-gcp-project-id

# =====================================================================
# Configurações do Agente (opcionais)
# =====================================================================

# Modelo Gemini a ser utilizado
# Opções: gemini-2.0-flash (recomendado, free tier), gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash

# Temperatura do modelo (0 = determinístico, 1 = criativo)
GEMINI_TEMPERATURE=0

# Número máximo de iterações do agente
AGENT_MAX_ITERATIONS=10
